<div class="ffg-sw-hud-content">
  <div class="hud-header">
    <span class="token-name">{{tokenName}}</span>
  </div>

  <div class="hud-body">
    {{#if hasData}}
      {{!-- Soak / Armor (read-only) --}}
      {{#if soak}}
      <div class="soak-row">
        <span class="stat-label">{{soak.label}}</span>
        <span class="soak-value">{{soak.value}}</span>
      </div>
      {{/if}}

      {{!-- Primary stat: Wounds or Hull Trauma --}}
      <div class="stat-row primary {{#if primary.exceeded}}exceeded{{/if}}">
        <span class="stat-label">{{primary.label}}</span>
        <div class="stat-controls">
          {{#if canEdit}}
          <button type="button" class="adjust-btn" data-action="adjust-stat"
                  data-key="{{primary.key}}" data-delta="-1">-1</button>
          {{/if}}
          <span class="stat-value">{{primary.value}} / {{primary.max}}</span>
          {{#if canEdit}}
          <button type="button" class="adjust-btn" data-action="adjust-stat"
                  data-key="{{primary.key}}" data-delta="1">+1</button>
          {{/if}}
        </div>
      </div>

      {{!-- Secondary stat: Strain or System Strain (hidden for minions) --}}
      {{#if secondary}}
      <div class="stat-row secondary {{#if secondary.exceeded}}exceeded{{/if}}">
        <span class="stat-label">{{secondary.label}}</span>
        <div class="stat-controls">
          {{#if canEdit}}
          <button type="button" class="adjust-btn" data-action="adjust-stat"
                  data-key="{{secondary.key}}" data-delta="-1">-1</button>
          {{/if}}
          <span class="stat-value">{{secondary.value}} / {{secondary.max}}</span>
          {{#if canEdit}}
          <button type="button" class="adjust-btn" data-action="adjust-stat"
                  data-key="{{secondary.key}}" data-delta="1">+1</button>
          {{/if}}
        </div>
      </div>
      {{/if}}
    {{/if}}
  </div>
</div>
